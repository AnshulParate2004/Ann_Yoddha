# Supabase (required for auth, DB, storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=images

# Optional: JWT verification (Project Settings > API > JWT Secret)
# SUPABASE_JWT_SECRET=your-jwt-secret

# Azure OpenAI (required for RAG recommendations)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Qdrant (required for RAG vector store)
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
# QDRANT_COLLECTION_NAME=wheat_disease_treatments

# Fallback auth (if not using Supabase Auth)
SECRET_KEY=change-me-in-production
